{
  "SessionStart": [
    {
      "hooks": [
        { "command": "node __DIR__/scripts/hooks/session-start.js", "timeout": 5000, "type": "command" }
      ],
      "matcher": "*"
    }
  ],
  "PostToolUse": [
    {
      "hooks": [
        { "command": "node __DIR__/scripts/hooks/observe.js", "timeout": 3000, "type": "command" }
      ],
      "matcher": "Edit|Write|Bash|NotebookEdit|Read|Grep|Glob"
    },
    {
      "hooks": [
        { "command": "node __DIR__/scripts/hooks/phase-manager.js", "timeout": 3000, "type": "command" }
      ],
      "matcher": "AskUserQuestion"
    }
  ],
  "PreToolUse": [
    {
      "hooks": [
        { "command": "node __DIR__/scripts/hooks/suggest-compact.js", "timeout": 3000, "type": "command" }
      ],
      "matcher": "Edit|Write"
    }
  ],
  "PreCompact": [
    {
      "hooks": [
        { "command": "node __DIR__/scripts/hooks/pre-compact.js", "timeout": 5000, "type": "command" }
      ],
      "matcher": "*"
    }
  ],
  "Stop": [
    {
      "hooks": [
        { "command": "node __DIR__/scripts/hooks/check-console-log.js", "timeout": 5000, "type": "command" }
      ],
      "matcher": "*"
    }
  ],
  "SessionEnd": [
    {
      "hooks": [
        { "command": "node __DIR__/scripts/hooks/session-end.js", "timeout": 5000, "type": "command" },
        { "command": "node __DIR__/scripts/hooks/evaluate-session.js", "timeout": 10000, "type": "command" }
      ],
      "matcher": "*"
    }
  ],
  "UserPromptSubmit": []
}
